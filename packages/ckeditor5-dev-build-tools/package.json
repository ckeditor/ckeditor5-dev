{
  "name": "@ckeditor/ckeditor5-dev-build-tools",
  "version": "57.4.0",
  "description": "Rolldown-based tools used to build CKEditor 5 packages.",
  "keywords": [],
  "author": "CKSource (http://cksource.com/)",
  "license": "GPL-2.0-or-later",
  "homepage": "https://github.com/ckeditor/ckeditor5-dev/tree/master/packages/ckeditor5-dev-build-tools",
  "bugs": "https://github.com/ckeditor/ckeditor5/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/ckeditor/ckeditor5-dev.git",
    "directory": "packages/ckeditor5-dev-build-tools"
  },
  "engines": {
    "node": ">=24.11.0",
    "npm": ">=5.7.1"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "bin",
    "dist"
  ],
  "bin": {
    "ckeditor5-dev-build-tools": "bin/build-project.js"
  },
  "dependencies": {
    "@rollup/pluginutils": "^5.3.0",
    "cssnano": "^7.1.4",
    "cssnano-preset-lite": "^4.0.4",
    "es-toolkit": "^1.45.1",
    "glob": "^13.0.6",
    "lightningcss": "^1.33.0",
    "pofile": "^1.1.4",
    "purgecss": "^8.0.0",
    "rolldown": "^1.1.2",
    "source-map": "^0.7.6",
    "upath": "^2.0.1"
  },
  "devDependencies": {
    "@types/css": "^0.0.38",
    "@types/node": "^22.19.17",
    "@vitest/coverage-v8": "^4.1.2",
    "type-fest": "^4.41.0",
    "vitest": "^4.1.2"
  },
  "scripts": {
    "build": "rolldown -c rolldown.config.ts",
    "dev": "rolldown -c rolldown.config.ts --watch",
    "test": "vitest run --config vitest.config.ts",
    "coverage": "vitest run --config vitest.config.ts --coverage",
    "test:dev": "vitest dev"
  },
  "depcheckIgnore": [
    "@types/css",
    "@vitest/coverage-v8"
  ]
}
